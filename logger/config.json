 {
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "simple": {
            "format": "[%(correlation_id)s] %(levelname)s: %(message)s"
        },
        "detailed": {
            "format": "[%(correlation_id)s] [%(levelname)s|%(module)s|L%(lineno)d] %(asctime)s: %(message)s",
            "datefmt": "%Y-%m-%dT%H:%M:%S%z"
        },
        "json": {
          "()": "logger.logging_manager.MyJSONFormatter",
          "fmt_keys": {
            "level": "levelname",
            "message": "message",
            "timestamp": "timestamp",
            "correlation_id": "correlation_id",
            "logger": "name",
            "module": "module",
            "function": "funcName",
            "line": "lineno",
            "thread_name": "threadName"
          }
        }
    },
    "filters": {
        "correlation_filter": {
            "()": "logger.logging_manager.CorrelationIdFilter"
        },
        "stdout_filter": {
            "()": "logger.logging_manager.MaxLevelFilter",
            "max_level": "INFO"
        }
    },
    "handlers": {
        "stdout": {
            "class": "logging.StreamHandler",
            "level": "DEBUG",
            "formatter": "simple",
            "stream": "ext://sys.stdout",
            "filters": ["stdout_filter"]
        },
        "stderr": {
            "class": "logging.StreamHandler",
            "level": "WARNING",
            "formatter": "simple",
            "stream": "ext://sys.stderr"
        },
        "file": {
            "class": "logging.handlers.RotatingFileHandler",
            "level": "DEBUG",
            "formatter": "json",
            "filename": "logs/my_app.log.jsonl",
            "maxBytes": 10000,
            "backupCount": 3
        },
        "queue_handler": {
            "class": "logging.handlers.QueueHandler",
            "handlers": ["stdout", "stderr", "file"],
            "respect_handler_level": true,
            "filters": ["correlation_filter"]
        }
    },
    "loggers": {
        "root": {
            "level": "DEBUG",
            "handlers": [
                "queue_handler"
            ]
        }
    }
}
